{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build:frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "backend/prisma/generated/**"
    }
  },
  "rewrites": [
    {
      "source": "/env.json",
      "destination": "/api/env.json"
    },
    {
      "source": "/signin",
      "destination": "/api/signin"
    },
    {
      "source": "/signup",
      "destination": "/api/signup"
    },
    {
      "source": "/query_ask",
      "destination": "/api/query_ask"
    },
    {
      "source": "/query_ask/:path*",
      "destination": "/api/query_ask/:path*"
    },
    {
      "source": "/conversations",
      "destination": "/api/conversations"
    },
    {
      "source": "/conversations/:path*",
      "destination": "/api/conversations/:path*"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
