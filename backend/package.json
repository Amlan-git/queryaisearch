{
  "name": "backend",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx ./index.ts",
    "start": "node --env-file=.env --import tsx ./index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tavily/core": "^0.7.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "ai": "^6.0.184",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "tsx": "^4.22.1",
    "zod": "^4.1.13"
  }
}
