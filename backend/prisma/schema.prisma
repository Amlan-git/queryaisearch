

generator client {
  provider = "prisma-client"
  output = "./generated"
	engineType = "client"
	runtime = "nodejs"
}

datasource db {
  provider = "postgresql"
  // URL configuration lives in prisma.config.ts (required by Prisma 7+).
  // Runtime queries use DATABASE_URL via the @prisma/adapter-pg adapter
  // in db.ts (transaction-mode pooler, port 6543, for Vercel serverless).
  // Migrations use DIRECT_URL via prisma.config.ts (session-mode pooler,
  // port 5432, because PgBouncer transaction mode doesn't support the
  // session-level features that migrations need).
}

//defining the schema 

model User {
  id            String     @id   @default(uuid())
  email         String  @unique
  provider      AuthProvider
  name          String 
  conversations Conversation[]

}

model Conversation {
  id        String    @id @default(uuid())
  title     String?
  slug      String?               // make optional until frontend needs it
  userId    String
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  content        String
  role           MessageRole
  sources        Json?                    // needed for history API
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

enum AuthProvider {
  GOOGLE
  GITHUB
}

enum MessageRole {
  USER
  ASSISTANT
}








